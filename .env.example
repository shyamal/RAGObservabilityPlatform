# ============================================================
# RAG Observability Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...                     # Required — OpenAI API key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma          # Local persistence path

# --- Langfuse (self-hosted via Docker) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...            # Required — from Langfuse UI
LANGFUSE_SECRET_KEY=sk-lf-...            # Required — from Langfuse UI
LANGFUSE_HOST=http://localhost:3000       # Default for local Docker setup

# --- Langfuse Postgres (Docker internal — change only if customizing) ---
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse
POSTGRES_DB=langfuse

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Evaluation ---
RAGAS_FAITHFULNESS_THRESHOLD=0.75        # CI fails below this score
RAGAS_RELEVANCE_THRESHOLD=0.70
EVAL_LATENCY_BUDGET_SECONDS=3.0          # P95 target
